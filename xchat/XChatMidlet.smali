    const-string v2, "\u041d\u0435 \u043c\u043e\u0436\u0435\u0448\u044c \u0432\u043e\u0439\u0442\u0438 \u0432 'CiTY'?\n___\n\u0423\u0431\u0435\u0434\u0438\u0441\u044c, \u0447\u0442\u043e \u0442\u0432\u043e\u0439 \u0442\u0435\u043b\u0435\u0444\u043e\u043d \u043f\u043e\u0434\u043a\u043b\u044e\u0447\u0435\u043d \u043a \u0443\u0441\u043b\u0443\u0433\u0435 GPRS-Internet. \u0414\u043b\u044f \u044d\u0442\u043e\u0433\u043e \u043f\u043e\u0437\u0432\u043e\u043d\u0438 \u0432 \u0430\u0431\u043e\u043d\u0435\u043d\u0442\u0441\u043a\u0443\u044e \u0441\u043b\u0443\u0436\u0431\u0443 \u0441\u0432\u043e\u0435\u0433\u043e \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0430.\n___\n\u0415\u0441\u043b\u0438 \u0443\u0441\u043b\u0443\u0433\u0430 \u043f\u043e\u0434\u043a\u043b\u044e\u0447\u0435\u043d\u0430, \u0430 'CiTY' \u043d\u0435 \u0437\u0430\u043f\u0443\u0441\u043a\u0430\u0435\u0442\u0441\u044f, \u043f\u0440\u043e\u0432\u0435\u0440\u044c \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u044f GPRS-Internet.\n___\n\u0422\u044b \u043c\u043e\u0436\u0435\u0448\u044c \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u044d\u0442\u043e \u0441\u0430\u043c\u043e\u0441\u0442\u043e\u044f\u0442\u0435\u043b\u044c\u043d\u043e \u0438\u043b\u0438 \u0432\u043e\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c\u0441\u044f \u043f\u043e\u043c\u043e\u0449\u044c\u044e \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0430 \u0430\u0431\u043e\u043d\u0435\u043d\u0442\u0441\u043a\u043e\u0439 \u0441\u043b\u0443\u0436\u0431\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043f\u0440\u0438\u0448\u043b\u0435\u0442 \u0442\u0435\u0431\u0435 \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0435 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438.\n___\n\u0427\u0442\u043e\u0431\u044b \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u043f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b \u0434\u043b\u044f \u0441\u0430\